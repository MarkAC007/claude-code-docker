# Required: Anthropic API key for Claude Code
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional: GitHub personal access token (enables gh CLI)
GITHUB_TOKEN=ghp_xxxxx

# Optional: Git identity for commits inside the container
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=your@email.com

# Optional: Override Claude Code model
# CLAUDE_CODE_MODEL=claude-sonnet-4-20250514

# Optional: AWS credentials (alternatively mount ~/.aws)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-west-1
